{
  "productName": "LAN Audio",
  "version": "1.11.0",
  "identifier": "com.example.lanaudio.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "LAN Audio",
        "width": 620,
        "height": 720,
        "minWidth": 420,
        "minHeight": 520,
        "resizable": true,
        "center": true,
        "visible": true,
        "decorations": true
      }
