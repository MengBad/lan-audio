{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "LAN Audio Desktop Client",
    "version":  "1.3.5",
    "identifier":  "com.example.lanaudio.desktop",
    "build":  {
                  "beforeDevCommand":  "",
                  "beforeBuildCommand":  "",
                  "frontendDist":  "../web"
              },
    "app":  {
                "withGlobalTauri":  true,
                "windows":  [
                                {
                                    "label":  "main",
                                    "title":  "LAN Audio Desktop Client",
                                    "width":  1180,
                                    "height":  760,
                                    "minWidth":  980,
                                    "minHeight":  680,
                                    "resizable":  true
                                }
                            ],
                "security":  {
                                 "csp":  null
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "icon":  [
                                "icons/icon.ico"
                            ]
               }
}
